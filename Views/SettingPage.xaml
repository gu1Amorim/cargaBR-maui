<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RotaSegura.SettingPage"
             BackgroundColor="#F5F5F5"
             Title="Perfil">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Border Padding="20" BackgroundColor="#1C2331" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,5" Opacity="0.2" Radius="10" />
                </Border.Shadow>

                <HorizontalStackLayout Spacing="20">
                    <Border WidthRequest="70" HeightRequest="70" BackgroundColor="#2962FF" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="35" />
                        </Border.StrokeShape>
                        <Label Text="JD" VerticalOptions="Center" HorizontalOptions="Center" 
                               TextColor="White" FontSize="24" FontAttributes="Bold" />
                    </Border>

                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="João Do Caminhão" TextColor="White" FontSize="20" FontAttributes="Bold" />
                        <Label Text="Motorista Premium" TextColor="#ABB2B9" FontSize="14" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <Label Text="Minha Conta" TextColor="Black" FontAttributes="Bold" FontSize="18" Margin="5,10,0,0" />

            <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White" Padding="5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout>
                    <Grid ColumnDefinitions="50, *, Auto" Padding="15">
                        <Label Text="👤" FontSize="20" VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Label Grid.Column="1" Text="Dados Pessoais" VerticalOptions="Center" TextColor="Black"/>
                        <Label Grid.Column="2" Text="❯" TextColor="Gray" VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="15,0"/>

                    <Grid ColumnDefinitions="50, *, Auto" Padding="15">
                        <Label Text="📄" FontSize="20" VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Label Grid.Column="1" Text="Documentos e CNH" VerticalOptions="Center" TextColor="Black"/>
                        <Label Grid.Column="2" Text="❯" TextColor="Gray" VerticalOptions="Center"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label Text="Assinatura" TextColor="Black" FontAttributes="Bold" FontSize="18" Margin="5,10,0,0" />

            <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout>
                        <Label Text="Plano Mensal Ativo" FontAttributes="Bold" TextColor="Black"/>
                        <Label Text="Renova em: 20/05/2026" TextColor="Gray" FontSize="12"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="Gerenciar" TextColor="#2962FF" VerticalOptions="Center" FontAttributes="Bold"/>
                </Grid>
            </Border>

            <Button Text="Sair da Conta" 
                    BackgroundColor="Transparent"
                    TextColor="#FF5252"
                    FontAttributes="Bold"
                    Margin="0,20,0,0" />

            <Label Text="Versão 1.0.0" HorizontalOptions="Center" TextColor="Silver" FontSize="12" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>