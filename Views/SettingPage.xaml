<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CargaBR.ViewModels"
             x:Class="CargaBR.Views.SettingPage"
             x:DataType="vm:SettingPageViewModel"
             Title="Perfil">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Border Padding="20" BackgroundColor="#1C2331" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,5" Opacity="0.2" Radius="10" />
                </Border.Shadow>

                <HorizontalStackLayout Spacing="20">
                    <Border WidthRequest="70" HeightRequest="70" BackgroundColor="#2962FF" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="35" />
                        </Border.StrokeShape>
                        <Label FontFamily="FASolid" Text="&#xf007;" VerticalOptions="Center" HorizontalOptions="Center"
                               TextColor="White" FontSize="24" />
                    </Border>

                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="{Binding UserName}" TextColor="White" FontSize="20" FontAttributes="Bold" />
                        <Label Text="{Binding IsPremium, Converter={StaticResource IsPremiumToLabelConverter}}" TextColor="#ABB2B9" FontSize="14" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <Label Text="Minha Conta" Style="{StaticResource SectionTitle}" />

            <Border Style="{StaticResource CardStyle}" Padding="5">
                <VerticalStackLayout>
                    <Grid ColumnDefinitions="50, *, Auto" Padding="15">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenPersonalDataCommand}" />
                        </Grid.GestureRecognizers>
                        <Label FontFamily="FASolid" Text="&#xf007;" FontSize="20" VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Label Grid.Column="1" Text="Dados Pessoais" VerticalOptions="Center"/>
                        <Label Grid.Column="2" FontFamily="FASolid" Text="&#xf054;" Style="{StaticResource MutedLabel}" VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}" Margin="15,0"/>

                    <Grid ColumnDefinitions="50, *, Auto" Padding="15">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenDocumentsCommand}" />
                        </Grid.GestureRecognizers>
                        <Label FontFamily="FASolid" Text="&#xf570;" FontSize="20" VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Label Grid.Column="1" Text="Documentos e CNH" VerticalOptions="Center"/>
                        <Label Grid.Column="2" FontFamily="FASolid" Text="&#xf054;" Style="{StaticResource MutedLabel}" VerticalOptions="Center"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label Text="Preferências" Style="{StaticResource SectionTitle}" />

            <Border Style="{StaticResource CardStyle}" Padding="15">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="Aparência do aplicativo" VerticalOptions="Center"/>
                    <Picker Grid.Column="1" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedThemeOption}" WidthRequest="120"/>
                </Grid>
            </Border>

            <Label Text="Assinatura" Style="{StaticResource SectionTitle}" />

            <Border Style="{StaticResource CardStyle}" Padding="15">
                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout>
                        <Label Text="{Binding IsPremium, Converter={StaticResource IsPremiumToLabelConverter}}" FontAttributes="Bold"/>
                        <Label Text="{Binding SubscriptionRenewalText}" Style="{StaticResource MutedLabel}" FontSize="12"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="Gerenciar"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                           VerticalOptions="Center" FontAttributes="Bold"/>
                </Grid>
            </Border>

            <Button Text="Sair da Conta"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                    FontAttributes="Bold"
                    Margin="0,20,0,0" />

            <Label Text="Versão 1.0.0" HorizontalOptions="Center" Style="{StaticResource MutedLabel}" FontSize="12" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
