<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RotaSegura.NavBarCustom">

    <Grid HeightRequest="70" BackgroundColor="Transparent" VerticalOptions="End">
        <Border BackgroundColor="White" StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.1" Radius="10" Offset="0,-2" />
            </Border.Shadow>
        </Border>

        <Grid x:Name="ItemsGrid" ColumnDefinitions="*,*,*,*,*">
            <Border x:Name="SelectionCircle"
            WidthRequest="50" HeightRequest="50"
            BackgroundColor="#512BD4"
            StrokeShape="RoundRectangle 25"
            HorizontalOptions="Center"
            VerticalOptions="Center"/>

            <Label Grid.Column="0" Text="🏠" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" x:Name="Icon0" InputTransparent="True"/>
            <Label Grid.Column="1" Text="🚛" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" x:Name="Icon1" InputTransparent="True"/>
            <Label Grid.Column="2" Text="📦" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" x:Name="Icon2" InputTransparent="True"/>
            <Label Grid.Column="3" Text="💰" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" x:Name="Icon3" InputTransparent="True"/>
            <Label Grid.Column="4" Text="⚙️" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" x:Name="Icon4" InputTransparent="True"/>

            <Button Grid.Column="0" BackgroundColor="Transparent" Clicked="NavigateCommand" CommandParameter="0"/>
            <Button Grid.Column="1" BackgroundColor="Transparent" Clicked="NavigateCommand" CommandParameter="1"/>
            <Button Grid.Column="2" BackgroundColor="Transparent" Clicked="NavigateCommand" CommandParameter="2"/>
            <Button Grid.Column="3" BackgroundColor="Transparent" Clicked="NavigateCommand" CommandParameter="3"/>
            <Button Grid.Column="4" BackgroundColor="Transparent" Clicked="NavigateCommand" CommandParameter="4"/>
        </Grid>
    </Grid>
</ContentView>