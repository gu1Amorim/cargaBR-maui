            <VerticalStackLayout Grid.Column="4" VerticalOptions="Center" Spacing="2" InputTransparent="True">
                <Path x:Name="Icon4" Fill="Gray" Aspect="Uniform" HeightRequest="25" WidthRequest="25" HorizontalOptions="Center"
              Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
