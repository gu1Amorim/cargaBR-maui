<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CargaBR.ViewModels"
             xmlns:models="clr-namespace:CargaBR.Models"
             x:Class="CargaBR.Views.TruckPage"
             x:DataType="vm:TruckPageViewModel"
             Title="Meu Caminhão">

    <Grid>
        <RefreshView Command="{Binding LoadTruckDataCommand}" IsRefreshing="{Binding IsBusy}">
            <ScrollView>
                <VerticalStackLayout Padding="20" Spacing="20">

                    <Border Padding="20" BackgroundColor="#1C2331" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,5" Opacity="0.3" Radius="10" />
                        </Border.Shadow>

                        <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                            <Label FontFamily="FASolid" Text="&#xf0d1;" FontSize="35" TextColor="White" VerticalOptions="Center"/>
                            <VerticalStackLayout>
                                <Label Text="{Binding Truck.Model}" TextColor="White" FontSize="22" FontAttributes="Bold" />
                                <Label Text="{Binding Truck.Type}" TextColor="#ABB2B9" FontSize="14" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Padding="15">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="Informações do Veículo" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="Placa Cavalo" Style="{StaticResource MutedLabel}"/>
                                <Label Grid.Column="1" Text="{Binding Truck.Plate}" FontAttributes="Bold"/>
                            </Grid>
                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}" />

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="Placa Carreta 1" Style="{StaticResource MutedLabel}"/>
                                <Label Grid.Column="1" Text="{Binding Truck.TrailerPlate}" FontAttributes="Bold"/>
                            </Grid>
                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}" />

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="Porte" Style="{StaticResource MutedLabel}"/>
                                <Label Grid.Column="1" Text="{Binding Truck.Size}" FontAttributes="Bold"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="Carretas Cadastradas" Style="{StaticResource SectionTitle}" Margin="5,10,0,0"/>

                    <CollectionView ItemsSource="{Binding Trailers}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Trailer">
                                <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,10">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding Description}" FontAttributes="Bold" FontSize="16"/>
                                        <Label Text="{Binding Plate, StringFormat='Placa: {0}'}" Style="{StaticResource MutedLabel}" FontSize="14"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button Text="Adicionar Carreta"
                            Command="{Binding AddTrailerCommand}"
                            Style="{StaticResource PrimaryButton}"/>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <Grid BackgroundColor="#AA000000" IsVisible="{Binding IsNotPremium}" InputTransparent="False">

            <Border VerticalOptions="Center" HorizontalOptions="Center" Margin="40" Padding="30" Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                    <Label FontFamily="FASolid" Text="&#xf023;" FontSize="50" HorizontalOptions="Center"/>
                    <Label Text="Acesso Bloqueado" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Assine o plano mensal para cadastrar e gerenciar seus caminhões."
                           HorizontalTextAlignment="Center" Style="{StaticResource MutedLabel}"/>
                    <Button Text="VER PLANOS" Style="{StaticResource PrimaryButton}" WidthRequest="200"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
