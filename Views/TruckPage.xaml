<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RotaSegura.TruckPage"
             BackgroundColor="#F5F5F5"
             Title="Meu Caminhão">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <Border Padding="20" BackgroundColor="#1C2331" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,5" Opacity="0.3" Radius="10" />
                    </Border.Shadow>

                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Label Text="🚛" FontSize="35" VerticalOptions="Center"/>
                        <VerticalStackLayout>
                            <Label Text="Scania R450" TextColor="White" FontSize="22" FontAttributes="Bold" />
                            <Label Text="Cavalo Mecânico" TextColor="#ABB2B9" FontSize="14" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <Border Padding="15" Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="Informações do Veículo" FontSize="18" FontAttributes="Bold" Margin="0,0,0,10" TextColor="Black"/>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Placa Cavalo" TextColor="Gray"/>
                            <Label Grid.Column="1" Text="ABC-1234" FontAttributes="Bold" TextColor="Black"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Placa Carreta 1" TextColor="Gray"/>
                            <Label Grid.Column="1" Text="DEF-5678" FontAttributes="Bold" TextColor="Black"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Porte" TextColor="Gray"/>
                            <Label Grid.Column="1" Text="Grande" FontAttributes="Bold" TextColor="Black"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Carretas Cadastradas" FontSize="18" FontAttributes="Bold" Margin="5,10,0,0" TextColor="Black"/>

                <Border Padding="15" Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <VerticalStackLayout>
                        <Label Text="Carreta 1 - Baú" FontAttributes="Bold" FontSize="16" TextColor="Black"/>
                        <Label Text="Placa: DEF-5678" TextColor="Gray" FontSize="14"/>
                    </VerticalStackLayout>
                </Border>

                <Button Text="Adicionar Carreta" 
                        Command="{Binding SaveTruckCommand}"
                        BackgroundColor="#2962FF" 
                        TextColor="White" 
                        CornerRadius="10" 
                        HeightRequest="50" 
                        FontAttributes="Bold"/>
            </VerticalStackLayout>
        </ScrollView>

        <Grid BackgroundColor="#AA000000" IsVisible="False" InputTransparent="False">

            <Border VerticalOptions="Center" HorizontalOptions="Center" Margin="40" Padding="30" BackgroundColor="White">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                    <Label Text="🔒" FontSize="60" HorizontalOptions="Center"/>
                    <Label Text="Acesso Bloqueado" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" TextColor="Black"/>
                    <Label Text="Assine o plano mensal para cadastrar e gerenciar seus caminhões." 
                           HorizontalTextAlignment="Center" TextColor="Gray"/>
                    <Button Text="VER PLANOS" BackgroundColor="#2962FF" CornerRadius="25" WidthRequest="200"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>