<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RotaSegura.LoadPage"
             BackgroundColor="#F5F5F5"
             Title="Cargas Disponíveis">

    <Grid RowDefinitions="Auto, *">

        <Border Margin="20,10" Padding="10" BackgroundColor="#F0F7FF" Stroke="#D0E4FF" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Text="🚚" VerticalOptions="Center"/>
                <Label Text="3 cargas disponíveis na sua região" TextColor="#0056B3" FontSize="14" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,0,20,20" Spacing="15">

                <Border Padding="20" BackgroundColor="White" Stroke="#E0E0E0" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Alimentos Não Perecíveis" FontAttributes="Bold" FontSize="18" TextColor="Black" VerticalOptions="Center"/>
                            <Border Grid.Column="1" BackgroundColor="#E8F5E9" Padding="10,5" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>
                                <Label Text="R$ 9.200,00" TextColor="#2E7D32" FontAttributes="Bold" />
                            </Border>
                        </Grid>

                        <VerticalStackLayout Spacing="8">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="📍" VerticalOptions="Center"/>
                                <Label Text="Origem:" TextColor="Black" FontAttributes="Bold"/>
                                <Label Text="Campinas - SP" TextColor="Gray"/>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="10">
                                <Label Text="📍" VerticalOptions="Center"/>
                                <Label Text="Destino:" TextColor="Black" FontAttributes="Bold"/>
                                <Label Text="Belo Horizonte - MG" TextColor="Gray"/>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="10">
                                <Label Text="⚖️" VerticalOptions="Center"/>
                                <Label Text="Peso:" TextColor="Black" FontAttributes="Bold"/>
                                <Label Text="22 toneladas" TextColor="Gray"/>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="10">
                                <Label Text="🛣️" VerticalOptions="Center"/>
                                <Label Text="Distância:" TextColor="Black" FontAttributes="Bold"/>
                                <Label Text="580 km" TextColor="Gray"/>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="10">
                                <Label Text="📅" VerticalOptions="Center"/>
                                <Label Text="Coleta:" TextColor="Black" FontAttributes="Bold"/>
                                <Label Text="22/04/2026" TextColor="Gray"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <Button Text="Aceitar Carga" 
                                BackgroundColor="#2962FF" 
                                TextColor="White" 
                                CornerRadius="10" 
                                HeightRequest="50" 
                                FontAttributes="Bold"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Border>

                <Border Padding="20" BackgroundColor="White" Stroke="#E0E0E0" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Equipamentos Industriais" FontAttributes="Bold" FontSize="18" TextColor="Black" VerticalOptions="Center"/>
                            <Border Grid.Column="1" BackgroundColor="#E8F5E9" Padding="10,5" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>
                                <Label Text="R$ 15.500,00" TextColor="#2E7D32" FontAttributes="Bold" />
                            </Border>
                        </Grid>

                        <HorizontalStackLayout Spacing="10">
                            <Label Text="📍" VerticalOptions="Center"/>
                            <Label Text="Origem:" TextColor="Black" FontAttributes="Bold"/>
                            <Label Text="Porto Alegre - RS" TextColor="Gray"/>
                        </HorizontalStackLayout>
                        <Button Text="Aceitar Carga" BackgroundColor="#2962FF" TextColor="White" CornerRadius="10" HeightRequest="50" FontAttributes="Bold" Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>