<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CargaBR.ViewModels"
             xmlns:models="clr-namespace:CargaBR.Models"
             x:Class="CargaBR.Views.LoadPage"
             x:DataType="vm:LoadPageViewModel"
             Title="Cargas Disponíveis">

    <Grid RowDefinitions="Auto, *">

        <Border Margin="20,10" Padding="10"
                BackgroundColor="{AppThemeBinding Light=#F0F7FF, Dark=#1B2A40}"
                Stroke="{AppThemeBinding Light=#D0E4FF, Dark=#2A3446}" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label FontFamily="FASolid" Text="&#xf0d1;" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                <Label Text="{Binding Loads.Count, StringFormat='{0} cargas disponíveis na sua região'}"
                       TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource PrimaryDark}}"
                       FontSize="14" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>

        <RefreshView Grid.Row="1" Command="{Binding LoadLoadsCommand}" IsRefreshing="{Binding IsBusy}">
            <ScrollView>
                <VerticalStackLayout Padding="20,0,20,20" Spacing="15">

                    <CollectionView ItemsSource="{Binding Loads}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Load">
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="{Binding Description}" FontAttributes="Bold" FontSize="18" VerticalOptions="Center"/>
                                            <Border Grid.Column="1"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource SuccessBackground}, Dark={StaticResource SuccessBackgroundDark}}"
                                                    Padding="10,5" StrokeThickness="0">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="15"/>
                                                </Border.StrokeShape>
                                                <Label Text="{Binding Value, StringFormat='R$ {0:N2}'}" TextColor="{StaticResource Success}" FontAttributes="Bold" />
                                            </Border>
                                        </Grid>

                                        <VerticalStackLayout Spacing="8">
                                            <HorizontalStackLayout Spacing="10">
                                                <Label FontFamily="FASolid" Text="&#xf3c5;" VerticalOptions="Center"/>
                                                <Label Text="Origem:" FontAttributes="Bold"/>
                                                <Label Text="{Binding OriginCity}" Style="{StaticResource MutedLabel}"/>
                                            </HorizontalStackLayout>

                                            <HorizontalStackLayout Spacing="10">
                                                <Label FontFamily="FASolid" Text="&#xf3c5;" VerticalOptions="Center"/>
                                                <Label Text="Destino:" FontAttributes="Bold"/>
                                                <Label Text="{Binding DestinationCity}" Style="{StaticResource MutedLabel}"/>
                                            </HorizontalStackLayout>

                                            <HorizontalStackLayout Spacing="10">
                                                <Label FontFamily="FASolid" Text="&#xf5cd;" VerticalOptions="Center"/>
                                                <Label Text="Peso:" FontAttributes="Bold"/>
                                                <Label Text="{Binding WeightTons, StringFormat='{0} toneladas'}" Style="{StaticResource MutedLabel}"/>
                                            </HorizontalStackLayout>

                                            <HorizontalStackLayout Spacing="10">
                                                <Label FontFamily="FASolid" Text="&#xf018;" VerticalOptions="Center"/>
                                                <Label Text="Distância:" FontAttributes="Bold"/>
                                                <Label Text="{Binding DistanceKm, StringFormat='{0} km'}" Style="{StaticResource MutedLabel}"/>
                                            </HorizontalStackLayout>

                                            <HorizontalStackLayout Spacing="10">
                                                <Label FontFamily="FASolid" Text="&#xf073;" VerticalOptions="Center"/>
                                                <Label Text="Coleta:" FontAttributes="Bold"/>
                                                <Label Text="{Binding PickupDate, StringFormat='{0:dd/MM/yyyy}'}" Style="{StaticResource MutedLabel}"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <Button Text="Aceitar Carga" Style="{StaticResource PrimaryButton}" Margin="0,10,0,0"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AcceptLoadCommand}"
                                                CommandParameter="{Binding}"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
