<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RotaSegura.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:RotaSegura" 
    Title="RotaSegura"
    FlyoutBehavior="Locked">
    <FlyoutItem Title="Início" Icon="home_icon.png">
        <ShellContent ContentTemplate="{DataTemplate local:HomePage}" Route="HomePage" />
    </FlyoutItem>

    <FlyoutItem Title="Caminhão" Icon="sales_icon.png">
        <ShellContent ContentTemplate="{DataTemplate local:TruckPage}" Route="TruckPage" />
    </FlyoutItem>

    <FlyoutItem Title="Carga" Icon="product_icon.png">
        <ShellContent ContentTemplate="{DataTemplate local:LoadPage}" Route="LoadPage" />
    </FlyoutItem>

    <FlyoutItem Title="Fretes" Icon="settings_icon.png">
        <ShellContent ContentTemplate="{DataTemplate local:FreightPage}" Route="FreightPage" />
    </FlyoutItem>

    <FlyoutItem Title="Perfil" Icon="settings_icon.png">
        <ShellContent ContentTemplate="{DataTemplate local:SettingPage}" Route="SettingPage" />
    </FlyoutItem>

</Shell>